# OpenWeatherMap API key — get yours at https://home.openweathermap.org/api_keys
# Copy this file to .env.local and fill in your key. NEVER commit .env.local.
OPENWEATHER_API_KEY=your_api_key_here

# Anthropic (Claude) API key — for the AI 服装・持ち物提案 feature.
# Get one at https://console.anthropic.com/ (paid API — usage is billed).
# Optional: without it the app still works, AI提案だけが無効になります。
ANTHROPIC_API_KEY=your_anthropic_api_key_here
